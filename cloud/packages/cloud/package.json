{
  "name": "@mentra/cloud",
  "version": "1.0.0",
  "private": true,
  "main": "dist/index.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "mkdir -p dist && bun x tsc -p tsconfig.json",
    "postbuild": "cp -r src/public dist/public && cp src/services/lc3/liblc3.wasm dist/services/lc3/liblc3.wasm",
    "start": "bun dist/index.js",
    "dev": "bun --watch src/index.ts",

    "staging": "NODE_ENV=staging tsx watch src/index.ts",
    "deploy": "bun run build && bun run start",
    "lint": "eslint src --ext .js,.jsx,.ts,.tsx",
    "test": "bun run ./src/tests/run-tests.ts",
    "test:visual": "bun run ./src/services/layout/tests/run-visual-tests.ts",
    "test:display": "bun run ./src/services/layout/tests/run-visual-tests.ts",
    "sentry:sourcemaps": "sentry-cli sourcemaps inject --org pierce-50 --project augmentos-cloud-dev ./dist && sentry-cli sourcemaps upload --org pierce-50 --project augmentos-cloud-dev ./dist",
    "use-linked": "bun link @mentra/utils @mentra/sdk @mentra/agents",
    "migrate:permissions": "bun run src/scripts/migrate-permissions.ts",
    "verify:permissions": "bun run src/scripts/verify-permissions.ts"
  },
  "author": "Mentra",

  "devDependencies": {
    "@types/babel__core": "^7.20.5",
    "@types/bcrypt": "^5.0.0",
    "@types/form-data": "^2.5.0",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.14",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.965.0",
    "@linear/sdk": "^75.0.0",
    "@logtail/pino": "^0.5.4",
    "@mentra/sdk": "workspace:*",
    "@mentra/types": "workspace:*",
    "@mentra/utils": "workspace:*",
    "@sentry/bun": "^9.1.0",
    "@sentry/cli": "^2.42.1",
    "@soniox/node": "^1.1.1",
    "@supabase/supabase-js": "^2.49.1",
    "@types/ali-oss": "^6.16.11",
    "ali-oss": "^6.23.0",
    "axios": "^1.7.4",
    "bun-types": "^1.3.5",
    "dotenv": "^10.0.0",
    "form-data": "^4.0.1",
    "hono": "^4.11.1",
    "jose": "^6.0.11",
    "jsonwebtoken": "^9.0.1",
    "mongodb": "^6.13.0",
    "mongoose": "^6.5.2",
    "openai": "^4.28.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "posthog-node": "^4.14.0",
    "resend": "^4.5.1",
    "uuid": "^11.0.5",
    "ws": "^8.18.1"
  }
}
