PORT=3000
PACKAGE_NAME=dev.mentra.streamtest
MENTRAOS_API_KEY=your_api_key_from_console

# Stream mode: "direct" or "managed"
# direct = glasses stream to your URL (RTMP/SRT), you handle receiving
# managed = glasses stream to MentraOS cloud relay, you get WebRTC/HLS/DASH viewer URLs
STREAM_MODE=direct

# Only needed for direct mode. Your local IP + port where FFmpeg is listening.
STREAM_URL=rtmp://YOUR_COMPUTER_IP:1935/live/test

# Enable verbose SDK logging (shows internal WebSocket messages, connection lifecycle, etc.)
# MENTRA_VERBOSE=true
