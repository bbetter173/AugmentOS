# Base Configuration
# cloud/.env
# This file contains the base configuration for the AugmentOS Cloud backend.
NODE_ENV=development
CLOUD_VERSION=2.0.0
BASE_PORT=8000
PORT=80

ADMIN_EMAILS=alex1115alex@gmail.com,alex1115alex+tester@gmail.com,isaiah@mentra.glass,israelov@mentra.glass,cayden@mentra.glass,nicolo@mentra.glass,nirhbay@mentra.glass,roger@mentra.glass

# Additional Pre-installed Apps (optional, comma-separated package names)
# These apps will be added on top of the default pre-installed apps
# Example: ADDITIONAL_PRE_INSTALLED_APPS=com.mentra.mentraai.beta,com.custom.app
ADDITIONAL_PRE_INSTALLED_APPS=

# Auto-delete Apps (optional, comma-separated package names)
# Apps specified here will be automatically removed from users' installed apps when they connect
# Useful for deprecating or removing apps across all users
# Example: DELETE_APP_BY_PACKAGE_NAME=cloud.augmentos.mira,com.deprecated.app
DELETE_APP_BY_PACKAGE_NAME=

# Services URLs
CLOUD_URL=cloud
APPSTORE_URL=appstore
LIVE_CAPTIONS_URL=live-captions
LIVE_TRANSLATION_URL=live-translation
DASHBOARD_MANAGER_URL=dashboard-manager
FLASH_URL=flash
ISAIAH_URL=isaiah
MIRA_URL=mira
NOTIFY_URL=notify

# Supabase env vars.
SUPABASE_URL=https://ykbiunzfbbtwlzdprmeh.supabase.co
SUPABASE_SERVICE_KEY=

# Datadog
DATADOG_API_KEY=
DD_API_KEY=

# MongoDB
MONGO_URL=

# Sentry
SENTRY_DSN=

# Azure Speech
AZURE_SPEECH_REGION=
AZURE_SPEECH_KEY=

# Soniox Speech
SONIOX_API_KEY=

# =============================================================================
# LLM Configuration
# =============================================================================
# Used for bug report summarization, Linear ticket deduplication, and AI features
#
# LLM_PROVIDER options: azure, openai, anthropic, google
# LLM_MODEL options by provider:
#   - azure/openai: gpt-5, gpt-5-mini, gpt-4o, gpt-4o-mini, o3, o3-mini, o4-mini
#   - anthropic:    claude-sonnet-4-20250514, claude-opus-4-20250514, claude-3-5-haiku-20241022
#   - google:       gemini-3.0-pro, gemini-2.5-pro, gemini-2.5-flash
LLM_MODEL=gpt-4o
LLM_PROVIDER=azure

# Azure OpenAI Configuration (required if LLM_PROVIDER=azure)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_INSTANCE_NAME=
AZURE_OPENAI_API_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Anthropic Configuration (required if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=

# OpenAI Configuration (required if LLM_PROVIDER=openai)
OPENAI_API_KEY=

# Google Vertex AI Configuration (required if LLM_PROVIDER=google)
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_CLOUD_PROJECT=

# Search API
SERPAPI_API_KEY=

# JWT Secrets
SUPABASE_JWT_SECRET=
AUGMENTOS_AUTH_JWT_SECRET=
JOE_MAMA_USER_JWT=

# PostHog
POSTHOG_PROJECT_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com% 

# AUTHING
AUTHING_APP_HOST=
AUTHING_APP_ID=
AUTHING_APP_SECRET=

# DEPLOYMENT_REGION=china
DEPLOYMENT_REGION=global

# ALIBABA
ALIBABA_ENDPOINT=
ALIBABA_WORKSPACE=
ALIBABA_DASHSCOPE_API_KEY=


# Cloudflare R2 Configuration
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=mentra-store
R2_PUBLIC_URL=https://mentra-store-cdn.mentraglass.com

# =============================================================================
# Incident Logging & Bug Reports
# =============================================================================
# These settings enable automated log collection when users submit bug reports.
# Logs are stored privately in R2 and linked to Linear tickets for debugging.

# R2 bucket for incident logs (private, separate from public assets)
R2_INCIDENTS_BUCKET=mentra-incidents

# BetterStack SQL Query API (for fetching cloud logs)
# Create credentials via BetterStack dashboard: AI SRE → MCP and API
BETTERSTACK_USERNAME=
BETTERSTACK_PASSWORD=
BETTERSTACK_SOURCE=                    # e.g., t373499_augmentos_logs (from BetterStack dashboard)

# Linear Integration (for automatic bug ticket creation)
LINEAR_API_KEY=
LINEAR_TEAM_ID=

# Agent API Key (for coding agents to access incident logs)
# Generate a random string and share with agents
MENTRA_AGENT_API_KEY=

# =============================================================================
# Slack Notifications
# =============================================================================
SLACK_WEBHOOK_USER_FEEDBACK=
SLACK_WEBHOOK_MINI_APP_SUBMISSION=

# =============================================================================
# Email Notifications (Resend)
# =============================================================================
RESEND_API_KEY=
