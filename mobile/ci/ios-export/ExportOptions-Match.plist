<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  Export plist for CI builds that signed with fastlane match.
	  Uses manual signing with the match-installed provisioning profile.
	  Local releases (laptop) use ExportOptions.plist (automatic signing)
	  instead — see release-ios.mjs for the selection logic.
	-->
	<key>method</key>
	<string>app-store-connect</string>
	<key>teamID</key>
	<string>T5XXXL6N36</string>
	<key>signingStyle</key>
	<string>manual</string>
	<key>provisioningProfiles</key>
	<dict>
		<key>com.mentra.mentra</key>
		<string>match AppStore com.mentra.mentra</string>
	</dict>
	<key>uploadBitcode</key>
	<false/>
	<key>uploadSymbols</key>
	<true/>
	<key>destination</key>
	<string>export</string>
</dict>
</plist>
